# App
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-a-32-byte-secret
ADMIN_EMAILS=admin@planeaciones.edu.mx

# Neon Postgres / Prisma (la integración Neon de Vercel inyecta ambas)
# DATABASE_URL: conexión pooled (con "-pooler") para el runtime serverless.
DATABASE_URL=postgresql://USER:PASSWORD@HOST-pooler:5432/DB?sslmode=require
# DATABASE_URL_UNPOOLED: conexión directa (sin "-pooler") para 'prisma migrate deploy'.
DATABASE_URL_UNPOOLED=postgresql://USER:PASSWORD@HOST:5432/DB?sslmode=require

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Google Gemini (motor de IA para la generación)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite

# App pública (para notification_url de Mercado Pago)
PUBLIC_BASE_URL=https://planeaciones.mx

# Mercado Pago
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=
MERCADOPAGO_SUCCESS_URL=https://planeaciones.mx/cuenta?paid=1
MERCADOPAGO_FAILURE_URL=https://planeaciones.mx/cuenta?paid=0

# Maintenance
DRAFT_TTL_HOURS=24
CRON_SECRET=
